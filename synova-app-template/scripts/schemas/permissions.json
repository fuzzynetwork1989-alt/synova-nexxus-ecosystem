{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Supanova Permissions Schema",
  "type": "object",
  "properties": {
    "tool_permissions": {
      "type": "object",
      "patternProperties": {
        "^app\\.[a-z_]+$": {
          "type": "object",
          "properties": {
            "requires_confirmation": { "type": "boolean" },
            "allowed_roles": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "rate_limit": {
              "type": "object",
              "properties": {
                "requests_per_minute": { "type": "integer", "minimum": 1 },
                "burst": { "type": "integer", "minimum": 1 }
              },
              "required": ["requests_per_minute", "burst"]
            },
            "data_access": {
              "enum": ["none", "read_only", "limited_write", "full_access"]
            }
          },
          "required": ["requires_confirmation", "allowed_roles", "rate_limit", "data_access"]
        }
      },
      "additionalProperties": false
    },
    "global_policies": {
      "type": "object",
      "properties": {
        "max_session_duration": { "type": "string" },
        "audit_all_actions": { "type": "boolean" },
        "log_sensitive_data": { "type": "boolean" },
        "require_user_presence": { "type": "boolean" },
        "auto_logout_idle": { "type": "string" }
      },
      "additionalProperties": false
    },
    "risk_levels": {
      "type": "object",
      "properties": {
        "low": {
          "type": "object",
          "properties": {
            "tools": { "type": "array", "items": { "type": "string" } },
            "auto_approve": { "type": "boolean" }
          },
          "required": ["tools", "auto_approve"]
        },
        "medium": {
          "type": "object",
          "properties": {
            "tools": { "type": "array", "items": { "type": "string" } },
            "auto_approve": { "type": "boolean" },
            "confirmation_required": { "type": "boolean" }
          },
          "required": ["tools", "auto_approve", "confirmation_required"]
        },
        "high": {
          "type": "object",
          "properties": {
            "tools": { "type": "array", "items": { "type": "string" } },
            "auto_approve": { "type": "boolean" },
            "confirmation_required": { "type": "boolean" }
          },
          "required": ["tools", "auto_approve", "confirmation_required"]
        }
      },
      "required": ["low", "medium", "high"]
    },
    "guardrails": {
      "type": "object",
      "properties": {
        "prevent_data_exfiltration": { "type": "boolean" },
        "limit_query_complexity": { "type": "boolean" },
        "sanitize_user_inputs": { "type": "boolean" },
        "validate_all_outputs": { "type": "boolean" },
        "rate_limit_per_user": { "type": "boolean" }
      },
      "required": [
        "prevent_data_exfiltration",
        "limit_query_complexity", 
        "sanitize_user_inputs",
        "validate_all_outputs",
        "rate_limit_per_user"
      ]
    }
  },
  "required": ["tool_permissions", "global_policies", "risk_levels", "guardrails"],
  "additionalProperties": false
}
