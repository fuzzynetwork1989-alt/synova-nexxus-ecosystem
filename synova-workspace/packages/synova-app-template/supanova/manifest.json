{
  "app_name": "App Name",
  "app_slug": "app-name",
  "version": "1.0.0",
  "supanova_version": "1.0.0",
  "capabilities": {
    "context_aware": true,
    "action_capable": true,
    "mode_adaptive": true,
    "memory_aware": false
  },
  "assistant_modes": {
    "default": "General assistance",
    "creator": "Drafting, rewriting, outlining, tone control",
    "utility": "Automation, workflows, smart defaults",
    "analyst": "Summarization, insights, anomaly detection"
  },
  "tools": [
    "app.search",
    "app.summarize", 
    "app.create_or_update",
    "app.navigate",
    "app.settings"
  ],
  "permissions": {
    "destructive_actions": "confirmation_required",
    "data_access": "context_based",
    "external_calls": "restricted"
  },
  "context_sources": [
    "current_route",
    "selected_entities",
    "user_actions",
    "system_state",
    "recent_errors"
  ],
  "ui_requirements": {
    "persistent_surface": true,
    "context_chips": true,
    "one_tap_actions": true,
    "permission_gates": true
  }
}
