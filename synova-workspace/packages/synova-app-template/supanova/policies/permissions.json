{
  "tool_permissions": {
    "app.search": {
      "requires_confirmation": false,
      "allowed_roles": ["owner", "editor", "viewer"],
      "rate_limit": {
        "requests_per_minute": 60,
        "burst": 10
      },
      "data_access": "read_only"
    },
    "app.summarize": {
      "requires_confirmation": false,
      "allowed_roles": ["owner", "editor", "viewer"],
      "rate_limit": {
        "requests_per_minute": 30,
        "burst": 5
      },
      "data_access": "read_only"
    },
    "app.create_or_update": {
      "requires_confirmation": true,
      "allowed_roles": ["owner", "editor"],
      "rate_limit": {
        "requests_per_minute": 20,
        "burst": 3
      },
      "data_access": "read_write",
      "destructive_actions": {
        "delete": "confirmation_required",
        "bulk_update": "confirmation_required",
        "sensitive_fields": "confirmation_required"
      }
    },
    "app.navigate": {
      "requires_confirmation": false,
      "allowed_roles": ["owner", "editor", "viewer"],
      "rate_limit": {
        "requests_per_minute": 100,
        "burst": 20
      },
      "data_access": "none"
    },
    "app.settings": {
      "requires_confirmation": false,
      "allowed_roles": ["owner", "editor"],
      "rate_limit": {
        "requests_per_minute": 10,
        "burst": 2
      },
      "data_access": "limited_write",
      "safe_settings": [
        "theme",
        "language", 
        "notifications",
        "display_density",
        "timezone"
      ],
      "restricted_settings": [
        "billing",
        "api_keys",
        "user_permissions",
        "data_export"
      ]
    }
  },
  "global_policies": {
    "max_session_duration": "24h",
    "audit_all_actions": true,
    "log_sensitive_data": false,
    "require_user_presence": true,
    "auto_logout_idle": "30min"
  },
  "risk_levels": {
    "low": {
      "tools": ["app.search", "app.summarize", "app.navigate"],
      "auto_approve": true
    },
    "medium": {
      "tools": ["app.settings"],
      "auto_approve": false,
      "confirmation_required": false
    },
    "high": {
      "tools": ["app.create_or_update"],
      "auto_approve": false,
      "confirmation_required": true
    }
  },
  "guardrails": {
    "prevent_data_exfiltration": true,
    "limit_query_complexity": true,
    "sanitize_user_inputs": true,
    "validate_all_outputs": true,
    "rate_limit_per_user": true
  }
}
