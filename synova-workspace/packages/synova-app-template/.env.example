# App Configuration
APP_NAME=App Name
APP_VERSION=1.0.0
NODE_ENV=development

# Supanova Configuration
SUPANOVA_ENABLED=true
SUPANOVA_API_URL=http://localhost:3001/api/supanova
SUPANOVA_API_KEY=your-supanova-api-key-here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/appname
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-here
SESSION_SECRET=your-session-secret-here

# External Services
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Monitoring & Observability
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-here
ANALYTICS_ID=your-analytics-id-here

# Feature Flags
FEATURE_ADVANCED_AI=true
FEATURE_BETA_FEATURES=false
FEATURE_DEBUG_MODE=false

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Email Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Development Only
DEBUG_SUPANOVA=false
MOCK_AI_RESPONSES=false
ENABLE_CORS=true
