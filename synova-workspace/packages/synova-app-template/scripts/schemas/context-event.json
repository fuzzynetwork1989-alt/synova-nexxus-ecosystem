{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Supanova Context Event Schema",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "route_change",
        "entity_selection", 
        "user_action",
        "system_error",
        "state_change",
        "search_query",
        "data_loaded"
      ]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "user_id": {
      "type": "string",
      "description": "Optional user identifier"
    },
    "session_id": {
      "type": "string",
      "description": "Unique session identifier"
    },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "description": "Event-specific data"
    }
  },
  "required": ["type", "timestamp", "session_id", "data"],
  "additionalProperties": false
}
