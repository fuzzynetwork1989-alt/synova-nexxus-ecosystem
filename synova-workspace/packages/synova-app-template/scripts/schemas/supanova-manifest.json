{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Supanova Manifest Schema",
  "type": "object",
  "properties": {
    "app_name": {
      "type": "string",
      "minLength": 1
    },
    "app_slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "supanova_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "context_aware": { "type": "boolean" },
        "action_capable": { "type": "boolean" },
        "mode_adaptive": { "type": "boolean" },
        "memory_aware": { "type": "boolean" }
      },
      "required": ["context_aware", "action_capable", "mode_adaptive"]
    },
    "assistant_modes": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "minProperties": 1
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5,
      "uniqueItems": true
    },
    "permissions": {
      "type": "object",
      "properties": {
        "destructive_actions": {
          "enum": ["confirmation_required", "auto_allowed", "disabled"]
        },
        "data_access": {
          "enum": ["none", "read_only", "limited_write", "full_access"]
        },
        "external_calls": {
          "enum": ["disabled", "restricted", "allowed"]
        }
      },
      "required": ["destructive_actions"]
    },
    "context_sources": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "ui_requirements": {
      "type": "object",
      "properties": {
        "persistent_surface": { "type": "boolean" },
        "context_chips": { "type": "boolean" },
        "one_tap_actions": { "type": "boolean" },
        "permission_gates": { "type": "boolean" }
      },
      "required": ["persistent_surface", "context_chips", "one_tap_actions", "permission_gates"]
    }
  },
  "required": [
    "app_name",
    "app_slug", 
    "version",
    "supanova_version",
    "capabilities",
    "assistant_modes",
    "tools",
    "permissions",
    "context_sources",
    "ui_requirements"
  ],
  "additionalProperties": false
}
